{
  "domain": "zhiyun_ble",
  "name": "Zhiyun Light (BLE)",
  "version": "0.1.0",
  "codeowners": [],
  "config_flow": true,
  "dependencies": ["bluetooth_adapters"],
  "documentation": "https://www.home-assistant.io/integrations/zhiyun_ble",
  "iot_class": "local_polling",
  "requirements": ["bleak-retry-connector>=3.5.0"],
  "bluetooth": [
    { "local_name": "PL0*" },
    { "local_name": "PL1*" },
    { "local_name": "PLB*" },
    { "local_name": "PLG*" },
    { "local_name": "PLM*" },
    { "local_name": "PLX*" }
  ]
}
